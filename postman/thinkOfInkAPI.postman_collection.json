						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"artista_pro\",\n  \"email\": \"artista@tattoo.com\",\n  \"password\": \"mi_password_seguro\",\n  \"gmail\": \"artista@gmail.com\",\n  \"roles\": [\"user\"]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/users",
							"host": ["{{base_url}}"],
							"path": ["users"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.access_token) {",
									"    pm.collectionVariables.set(\"jwt_token\", response.access_token);",
									"    console.log(\"¡Token guardado automáticamente en la variable de colección!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"artista@tattoo.com\",\n  \"password\": \"mi_password_seguro\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
